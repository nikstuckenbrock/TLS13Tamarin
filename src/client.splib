rule receive_server_auth:
    let

        // Certificate
        certificateMessage = Certificate('0', pk(~longTermKeyServer))
        messages = <p_messages, certificateMessage>

        receivedCertificateVerifyMessage = CertificateVerify(signature)
        messages = <messages, receivedCertificateVerifyMessage>

        finishedMessage = Finished(verify_data)
        messages = <messages, finishedMessage>

        earlyMasterSecret = Expand(p_masterSecret, <'ems', <h(messages)>>, '32')
        clientApplicationTrafficSecret = Expand(p_masterSecret, <'clientats', <h(messages)>>, '32')
        serverApplicationTrafficSecret = Expand(p_masterSecret, <'serverats', <h(messages)>>, '32')
        serverApplicationTrafficKey = Expand(serverApplicationTrafficSecret, <'adke_wk', '0'>, '32')
        auth_status = <'auth', '0'>
    in
    [
        In(senc{<certificateMessage,receivedCertificateVerifyMessage,finishedMessages>}p_handshakeKeyServer),
        F_State_C2d(
            tid,
            $C,
            $S,
            p_res_psk,
            p_messages,
            p_nc,
            p_ns,
            p_g,
            p_sg,
            p_hrr,
            p_x,
            p_y,
            p_gx,
            p_gy,
            p_gxy,
            p_psk_ke_mode,
            p_psk_id,
            p_edi,
            p_es,
            p_handshakeSecret,
            p_masterSecret,
            p_cats,
            p_sats,
            p_handshakeKeyClient,
            p_handshakeKeyServer,
            p_auth_status,
            p_ems,
            p_rms,
            p_cert_req
        ),
        !Pk($S, pk(~longTermKeyServer))
    ]
    --[
        C2d(tid),
        Instance(tid, $C, 'client')
    ]->
    [
        F_State_C3(
            tid,
            $C,
            $S,
            p_res_psk,
            messages,
            p_nc,
            p_ns,
            p_g,
            p_sg,
            p_hrr,
            p_x,
            p_y,
            p_gx,
            p_gy,
            p_gxy,
            p_psk_ke_mode,
            p_psk_id,
            p_edi,
            p_es,
            p_handshakeSecret,
            p_masterSecret,
            clientApplicationTrafficSecret,
            serverApplicationTrafficSecret,
            p_handshakeKeyClient,
            p_handshakeKeyServer,
            auth_status,
            earlyMasterSecret,
            p_rms,
            p_cert_req
        )
    ]

rule client_auth:
    let
        verify_data = hmac(Expand(Expand(p_handshakeSecret, <'clienthts', <h(p_messages)>>, '32'), <'fin', '0'>, '32'), h(p_messages))
        finishedMessage = Finished(verify_data)
        messages = <p_messages, finishedMessage>

        resumptionMasterSecret = Expand(p_masterSecret, <'rms', <h(messages)>>, '32')
        clientApplicationTrafficKey = Expand(p_clientApplicationTrafficSecret, <'adke_wk', '0'>, '32')
        serverApplicationTrafficKey = Expand(p_serverApplicationTrafficSecret, <'adke_wk', '0'>, '32')
    in
    [
        F_State_C3(
            tid,
            $C,
            $S,
            p_res_psk,
            p_messages,
            p_nc,
            p_ns,
            p_g,
            p_sg,
            p_hrr,
            p_x,
            p_y,
            p_gx,
            p_gy,
            p_gxy,
            p_psk_ke_mode,
            p_psk_id,
            p_edi,
            p_es,
            p_handshakeSecret,
            p_masterSecret,
            p_clientApplicationTrafficSecret,
            p_serverApplicationTrafficSecret,
            p_handshakeKeyClient,
            p_handshakeKeyServer,
            p_auth_status,
            p_earlyMasterSecret,
            p_rms,
            p_cert_req
        )
    ]
    --[
        C3(tid)
    ]->
    [
        Out(senc{finishedMessage}p_handshakeKeyClient),
        L_State_C4(
            tid,
            $C,
            $S,
            p_res_psk,
            p_messages,
            p_nc,
            p_ns,
            p_g,
            p_sg,
            p_hrr,
            p_x,
            p_y,
            p_gx,
            p_gy,
            p_gxy,
            p_psk_ke_mode,
            p_psk_id,
            p_edi,
            p_es,
            p_handshakeSecret,
            p_masterSecret,
            p_clientApplicationTrafficSecret,
            p_serverApplicationTrafficSecret,
            p_handshakeKeyClient,
            p_handshakeKeyServer,
            p_auth_status,
            p_earlyMasterSecret,
            resumptionMasterSecret,
            p_cert_req
        )
    ]

rule client_auth_cert:
    let
        p_cert_req = '1'
        p_psk_ke_mode = 'na'

        // Certificate
        certificateMessage = Certificate('0', pk(~longTermKeyClient))
        messages = <p_messages, certificateMessage>

        // CertificateVerify
        signature = sign{<'client_cv', <h(messages)>>}~longTermKeyClient
        certificateVerifyMessage = CertificateVerify(signature)
        messages = <messages, certificateVerifyMessage>

        // Finished
        verify_data = hmac(Expand(Expand(p_handshakeSecret, <'clienthts', <h(messages)>>, '32'), <'fin', '0'>, '32'), h(messages))
        finishedMessage = Finished(verify_data)
        messages = <messages, finishedMessage>

        rms = Expand(p_ms, <'rms', <h(messages)>>, '32')

        serverApplicationTrafficKey = Expand(serverApplicationTrafficSecret, <'adke_wk', '0'>, '32')
        clientApplicationTrafficKey = Expand(clientApplicationTrafficSecret, <'adke_wk', '0'>, '32')

        auth_status = <'auth', 'auth'>
    in
    [
        F_State_C2d(
            tid,
            $C,
            $S,
            p_res_psk,
            p_messages,
            p_nc,
            p_ns,
            p_g,
            p_sg,
            p_hrr,
            p_x,
            p_y,
            p_gx,
            p_gy,
            p_gxy,
            p_psk_ke_mode,
            p_psk_id,
            p_edi,
            p_es,
            p_handshakeSecret,
            p_masterSecret,
            p_clientApplicationTrafficSecret,
            p_serverApplicationTrafficSecret,
            p_handshakeKeyClient,
            p_handshakeKeyServer,
            p_auth_status,
            p_earlyMasterSecret,
            p_rms,
            p_cert_req
        ),
        !Ltk($C, ~longTermKeyClient)
    ]
    --[
        C3_cert(tid)
    ]->
    [
        F_State_C3(
            tid,
            $C,
            $S,
            p_res_psk,
            p_messages,
            p_nc,
            p_ns,
            p_g,
            p_sg,
            p_hrr,
            p_x,
            p_y,
            p_gx,
            p_gy,
            p_gxy,
            p_psk_ke_mode,
            p_psk_id,
            p_edi,
            p_es,
            p_handshakeSecret,
            p_masterSecret,
            p_clientApplicationTrafficSecret,
            p_serverApplicationTrafficSecret,
            p_handshakeKeyClient,
            p_handshakeKeyServer,
            p_auth_status,
            p_earlyMasterSecret,
            rms,
            p_cert_req
        ),
        Out(senc{<certificateMessage,certificateVerifyMessage,finishedMessage>}p_handshakeKeyClient)
    ]

rule receive_new_session_ticket:
    let
        p_rms = Expand(p_ms, <'rms', <h(p_messages)>>, '32')
        ticket_extension = <
            <'46', $max_early_data_size>
        >
        receivedMessage = NewSessionTicket($ticket_lifetime, ticket_age_add, ticket, ticket_extension)
    in
    [
        RecvStream(tid, $C, $S, auth_status, serverApplicationTrafficKey),
        In(senc{receivedMessage}serverApplicationTrafficKey),
        L_State_C4(
            tid,
            $C,
            $S,
            p_res_psk,
            p_messages,
            p_nc,
            p_ns,
            p_g,
            p_sg,
            p_hrr,
            p_x,
            p_y,
